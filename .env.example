# ─────────────────────────────────────────
# FluxSentinel AI — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=*

# GitLab Integration
GITLAB_TOKEN=your_gitlab_pat_here
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here
GITLAB_API_URL=https://gitlab.com/api/v4

# Anthropic AI
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini (free tier — get key at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Resend Email
RESEND_API_KEY=your_resend_key_here

# JWT Auth (must be at least 32 characters)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# Dashboard Credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_secure_password_here

# Email Recipients
TEAM_LEAD_EMAIL=teamlead@example.com
FROM_EMAIL=fluxsentinel@yourdomain.com
